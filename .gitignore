# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules
.pnpm-store/

# environment variables — never commit secrets
.env
.env.local
.env.*
!.env.example

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

# Cursor / project instructions
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# local caches
.cache/
.local/

# User data — never commit PII
artifacts/data/users.json
artifacts/api-server/data/users.json
artifacts/api-server/data/
data/
data/uploads/

# build/cache folders
.next/
build/
out/